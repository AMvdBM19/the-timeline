<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>The Timeline</title>
        <link
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous"
        />
      </head>
      <body class="bg-light">
        <div class="container py-5">
          <h1 class="mb-4 text-center">The Timeline</h1>

          <div class="row justify-content-center">
            <div class="col-lg-8">

              <!-- CREATE POST FORM -->
              <div class="card mb-4 shadow-sm border-primary">
                <div class="card-header bg-primary text-white">
                  <h5 class="mb-0">Create a New Post</h5>
                </div>
                <div class="card-body">
                  <form action="/posts" method="POST">
                    <div class="mb-3">
                      <label for="postInput" class="form-label">What's on your mind?</label>
                      <textarea
                        class="form-control"
                        id="postInput"
                        name="post"
                        rows="4"
                        placeholder="Write your post here (minimum 25 characters)..."
                        required
                        minlength="25"
                      ></textarea>
                      <small class="form-text text-muted">Minimum 25 characters required</small>
                    </div>
                    <button type="submit" class="btn btn-primary">Post</button>
                  </form>
                </div>
              </div>

              <!-- DISPLAY ALL POSTS -->
              <% if (posts.length === 0) { %>
                <div class="alert alert-info text-center">
                  No posts yet. Be the first to create one!
                </div>
              <% } else { %>
                <% posts.forEach(function(post) { %>
                  <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                      <!-- Post Header: Date and Action Buttons -->
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">
                          <%= new Date(post.createdAt).toLocaleString() %>
                        </span>
                        <div class="btn-group btn-group-sm" role="group">
                          <!-- Edit Button -->
                          <button
                            type="button"
                            class="btn btn-outline-warning"
                            data-bs-toggle="modal"
                            data-bs-target="#editModal"
                            data-post-id="<%= post._id %>"
                            data-post-text="<%= post.post %>"
                            onclick="prepareEditForm(this)"
                          >
                            ✏️ Edit
                          </button>

                          <!-- Delete Button -->
                          <form
                            action="/posts/<%= post._id %>?_method=DELETE"
                            method="POST"
                            style="display: inline;"
                            onsubmit="return confirm('Are you sure you want to delete this post?')"
                          >
                            <button type="submit" class="btn btn-outline-danger">
                              🗑️ Delete
                            </button>
                          </form>
                        </div>
                      </div>

                      <!-- Post Content -->
                      <p class="card-text mb-0"><%= post.post %></p>

                      <!-- Comments section -->
                      <hr class="my-3" />
                      <h6 class="text-muted mb-2">Comments</h6>
                      <% if (post.comments && post.comments.length > 0) { %>
                        <% post.comments.forEach(function(comment) { %>
                          <div class="border-start border-secondary border-2 ps-2 mb-2 small">
                            <span class="text-muted"><%= new Date(comment.createdAt).toLocaleString() %></span>
                            <p class="mb-0 mt-1"><%= comment.content %></p>
                          </div>
                        <% }); %>
                      <% } else { %>
                        <p class="text-muted small mb-2">No comments yet.</p>
                      <% } %>
                      <form action="/posts/<%= post._id %>/comments" method="POST" class="mt-2">
                        <textarea
                          class="form-control form-control-sm"
                          name="content"
                          rows="2"
                          placeholder="Write a comment (minimum 25 characters)..."
                          required
                          minlength="25"
                        ></textarea>
                        <small class="form-text text-muted">Minimum 25 characters</small>
                        <button type="submit" class="btn btn-sm btn-outline-secondary mt-1">Add Comment</button>
                      </form>
                    </div>
                  </div>
                <% }); %>
              <% } %>

            </div>
          </div>
        </div>

        <!-- EDIT POST MODAL -->
        <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <form id="editForm" method="POST">
                <div class="modal-body">
                  <div class="mb-3">
                    <label for="editPostInput" class="form-label">Edit your post</label>
                    <textarea
                      class="form-control"
id="editPostInput"
                      name="post"
                      rows="4"
                      required
                      minlength="25"
                    ></textarea>
                    <small class="form-text text-muted">Minimum 25 characters required</small>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button type="submit" class="btn btn-warning">Update Post</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Bootstrap JS for Modal Functionality -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        <!-- JavaScript for Edit Form Handler -->
        <script>
          function prepareEditForm(button) {
            const postId = button.getAttribute('data-post-id');
            const postText = button.getAttribute('data-post-text');

            // Fill the modal textarea with the current post text
            document.getElementById('editPostInput').value = postText;

            // Update the form action to the correct route with PUT method
            const editForm = document.getElementById('editForm');
            editForm.action = `/posts/${postId}?_method=PUT`;
            editForm.method = 'POST';  // We use POST with ?_method=PUT because HTML forms don't support PUT directly
          }
        </script>
      </body>
</html>